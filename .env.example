# Copy this file to .env and fill in your values.
# If these are left unset, the script will prompt you at runtime instead.

# X account to log in with
LOGIN_USERNAME=
LOGIN_PASSWORD=

# Profile to scrape
TARGET_USERNAME=

# Optional: stop scraping when this exact tweet text is encountered.
# Leave blank to collect up to MAX_TWEETS instead.
STOP_AT_TWEET=

# Maximum number of tweets to collect (default: 2000)
MAX_TWEETS=2000

# Output file path (default: tweets_dump.json)
OUTPUT_FILE=tweets_dump.json
